<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#151515"
    android:padding="16dp">

    <TextView
        android:id="@+id/steamTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/steam_title"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/steamLoginSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#252525"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/steam_api_key"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/steamApiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your Steam API Key"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#333333"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Steam ID (64-bit)"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/steamIdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your Steam ID"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#333333"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/steamConnectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/steam_connect"
            android:backgroundTint="#66C0F4"
            android:textColor="#000000"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/steamProfileSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#252525"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/steamAvatar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="#333333"
                android:scaleType="centerCrop"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/steamPersonaName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Steam Username"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/steamIdDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Steam ID: 76561198000000000"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"/>

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/steamDisconnectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/steam_disconnect"
            android:backgroundTint="#FF4444"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <TextView
        android:id="@+id/steamGamesTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/steam_games"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:visibility="gone"/>

    <ProgressBar
        android:id="@+id/steamProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/steamStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/steam_not_connected"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_gravity="center"
        android:gravity="center"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/steamGamesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

</LinearLayout>
